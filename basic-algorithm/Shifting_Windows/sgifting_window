#include<iostream>
#include<vector>
using namespace std;

//模板一:固定窗口大小k
int fixedWindow(vector<int>& nums, int k){
    int sum = 0, res = 0;
    for(int i = 0; i < nums.size(); i ++){
        sum += nums[i]; //nums[i]进入窗口
        if(i >= k - 1){ //窗口大小达到k，更新答案
            res = max(res, sum);//更新答案
            sum -= nums[i - k + 1];//离开窗口
        }
    }
    return res;
}
