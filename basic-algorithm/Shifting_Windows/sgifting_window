// 模板五:覆盖型(最小覆盖子串,need 计数)
string minCover(string s, string t){
    unordered_map<char, int> need, win;
    for(char c : t) need[c] ++;
    int valid = 0, start = 0, len = INT_MAX;
    for(int i = 0, j = 0; i < s.size(); i ++){
        char c = s[i];
        if(need.count(c) && ++win[c] == need[c]) valid ++;//窗口状态更新
        while(valid == need.size()){
            if(i - j + 1 < len){
                start = j;
                len = i - j + 1;
            }
            char d = s[j ++];
            if(need.count(d) && win[d]-- == need[d]) valid --;
        }
    }
    return len == INT_MAX ? "" : s.substr(start, len);
}

