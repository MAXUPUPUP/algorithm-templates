// 模板四:恰好/最多约束(求"恰好K个"= 最多K个 - 最多K-1个)
int atMostK(vector<int>& nums, int k){
    int res = 0;
    unordered_map<int, int> hash;
    for(int i = 0, j = 0; i < nums.size(); i ++){
        hash[nums[i]] ++;
        if(hash[nums[i]] == 1) k --;//新元素，约束条件-1
        while(k < 0){
            if(--hash[nums[j ++]] == 0) k ++;
        }
        res += i - j + 1;//满足约束条件的子数组个数
    }
    return res;
}// 恰好K个 = atMostK(k) - atMostK(k-1)

