// 模板二:可变窗口(满足条件时收缩)
int variablewindows(vector<int>& nums, int target){
    int sum = 0, res = INT_MAX;
    for(int i = 0, j = 0; i < nums.size(); i ++){
        sum += nums[i];
        while(sum >= target){// 不满足约束就收缩
            res = min(res, i - j + 1);
            sum -= nums[j ++];// 缩小窗口
        }
    }
    return res == INT_MAX ? 0 : res;
    


}
